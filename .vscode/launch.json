{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    {
        "name": "New Covariant Sample",
        "type": "cppdbg",
        "request": "launch",
        "program": "${workspaceFolder}/covariant2",
        "args": ["--smooth=1", "--threshold=.0001", "--normal=0", "--snake=1", "--exponential=0", "--events=1000000", "--save"],
        "stopAtEntry": false,
        "cwd": "${workspaceFolder}",
        "environment": [],
        "externalConsole": false,
        "MIMode": "gdb",
        "setupCommands": [
            {
                "description": "Enable pretty-printing for gdb",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
            },
            {
                "description": "Set Disassembly Flavor to Intel",
                "text": "-gdb-set disassembly-flavor intel",
                "ignoreFailures": true
            }
        ]
    },
    {
        "name": "Load Covariant",
        "type": "cppdbg",
        "request": "launch",
        "program": "${workspaceFolder}/covariant2",
        "args": ["--load", "--smooth=5", "--threshold=.01"],
        "stopAtEntry": false,
        "cwd": "${workspaceFolder}",
        "environment": [],
        "externalConsole": false,
        "MIMode": "gdb",
        "setupCommands": [
            {
                "description": "Enable pretty-printing for gdb",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
            },
            {
                "description": "Set Disassembly Flavor to Intel",
                "text": "-gdb-set disassembly-flavor intel",
                "ignoreFailures": true
            }
        ]
    },
    {
        "name": "Run Matlab Script",
        "type": "cppdbg",
        "request": "launch",
        "program": "/bin/bash",
        "args": [
            "-c",
            "matlab -nodesktop -nosplash -r plot_isosurface"
        ],
        "stopAtEntry": false,
        "cwd": "${workspaceFolder}",
        "environment": [],
        "externalConsole": false,
        "MIMode": "gdb"
    }
    ]
}